# Copy this file to .env (shared defaults) or .env.local (your machine only).
# .env.local overrides .env. Both are git-ignored.

# MySQL database (Cloudways). Leads are dual-written here (primary) and to
# storage/leads.jsonl (fallback). Leave DB_USER/DB_PASS empty to disable the DB
# write entirely. After setting these, run: php db-migrate.php
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pdqhvfnunn
DB_USER=
DB_PASS=

# Google Maps JavaScript API key with the Places API enabled.
# Used for address autocomplete on the qualify form.
GOOGLE_MAPS_API_KEY=AIzaSyA9DiggWsawF9hLRIxw_-jMhttV7KGvEs8

# Firebase web config for phone-number verification (Authentication > Phone).
# Find these in Firebase Console > Project settings > Your apps > SDK setup.
FIREBASE_API_KEY=AIzaSyCs6f0iNKiPqVH7edRcmQ6jy2qzvkwgRoE
FIREBASE_AUTH_DOMAIN=fitz-media-group.firebaseapp.com
FIREBASE_PROJECT_ID=fitz-media-group
FIREBASE_APP_ID=1:831934480658:web:11d966e4dfad59875a73cb
FIREBASE_MESSAGING_SENDER_ID=831934480658

# LeadProsper lead ingestion (https://api.leadprosper.io/direct_post).
# Get these from your LeadProsper campaign's "Direct Post" instructions.
LP_CAMPAIGN_ID=28202
LP_SUPPLIER_ID=107402
LP_KEY=107402
LP_TEST_MODE=false

# Lead certification. TrustedForm needs no key; set false to disable its script.
TRUSTEDFORM_ENABLED=true
# Jornaya (LeadiD) campaign GUID. Leave empty to disable the Jornaya script.
JORNAYA_CAMPAIGN_ID=

# Everflow client-side tracking. Domain = your account's tracking domain (no protocol),
# e.g. track.example.com. Offer ID is the Everflow offer the click belongs to.
# Empty domain disables the SDK. The transaction id is read into hid_ef_tid.
EVERFLOW_DOMAIN=
EVERFLOW_OFFER_ID=

# Equifax Consumer Credit Report (Equifax Developer Platform, OAuth2 client-credentials).
# Pulls a credit report server-side to read a verified total-debt figure for qualification.
# Leave the resolved API key/secret empty to skip the pull (graceful fallback).
#
# EQUIFAX_MODE = 'production' uses the prod host + PRODUCTION_* keys; otherwise sandbox.
EQUIFAX_MODE=sandbox
EQUIFAX_SANDBOX_API_KEY=
EQUIFAX_SANDBOX_API_SECRET=
EQUIFAX_PRODUCTION_API_KEY=
EQUIFAX_PRODUCTION_API_SECRET=
# OAuth2 scope, host + endpoint paths. Defaults suit the Consumer Credit Report product;
# EQUIFAX_API_BASE auto-selects prod/sandbox from EQUIFAX_MODE unless overridden here.
# Leave EQUIFAX_SCOPE empty: the token endpoint returns 400 invalid_scope when a scope is
# sent and only issues a token when it's omitted. Set it only if your account requires one.
EQUIFAX_SCOPE=
#EQUIFAX_API_BASE=
EQUIFAX_TOKEN_PATH=/v2/oauth/token
# OneView consumer-credit report (matches the granted token scope).
EQUIFAX_PRODUCT_PATH=/business/oneview/consumer-credit/v1/reports/credit-report
# Entitled OneView credit-model id; leave empty to omit the models block.
EQUIFAX_MODEL_ID=05734
# Account identifiers from your Equifax welcome kit / contract.
EQUIFAX_MEMBER_NUMBER=
EQUIFAX_SECURITY_CODE=
EQUIFAX_CUSTOMER_CODE=
EQUIFAX_ECOA_INQUIRY_TYPE=Individual
EQUIFAX_MULTIPLE_REPORT_INDICATOR=1
# Optional: dot-path to a precomputed total-debt attribute if your product returns one.
# Leave empty to sum trade-line balances from the report instead.
EQUIFAX_TOTAL_DEBT_PATH=
